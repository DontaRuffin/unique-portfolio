---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const notes = await getCollection('notes', ({ data }) => data.publish);
  return notes.map((note) => ({
    params: { slug: note.slug },
    props: { note },
  }));
}

const { note } = Astro.props;
const { Content } = await note.render();
const { title, description, tags, status, updated } = note.data;
---

<Layout title={`${title} | Digital Garden`} description={description}>
  <!-- Note Header -->
  <section class="relative py-24 bg-brutal-cream border-b-3 border-brutal-black">
    <div class="absolute inset-0 bg-dots opacity-10"></div>
    <div class="relative max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <a href="/garden" class="inline-flex items-center gap-2 font-mono text-xs uppercase tracking-wider text-gray-600 hover:text-brutal-violet transition-colors mb-8">
        <span aria-hidden="true">←</span> Back to Garden
      </a>

      <!-- Status -->
      <div class="flex items-center gap-2 mb-4">
        <span class={`w-3 h-3 rounded-full ${
          status === 'evergreen' ? 'bg-green-500' :
          status === 'budding' ? 'bg-yellow-500' : 'bg-gray-400'
        }`}></span>
        <span class="font-mono text-xs uppercase tracking-wider text-gray-500">{status}</span>
      </div>

      <h1 class="text-brutal-headline text-4xl sm:text-5xl md:text-6xl mb-6">
        {title}
      </h1>

      {description && (
        <p class="font-body text-xl text-gray-700 leading-relaxed mb-6">
          {description}
        </p>
      )}

      <!-- Tags -->
      {tags && tags.length > 0 && (
        <div class="flex flex-wrap gap-2">
          {tags.map((tag) => (
            <span class="px-3 py-1 text-xs font-mono uppercase tracking-wider border-3 border-brutal-black bg-brutal-white">
              {tag}
            </span>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- Note Body -->
  <section class="py-16 bg-brutal-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <article class="prose-brutal font-body text-gray-800 leading-relaxed space-y-4">
        <Content />
      </article>

      {updated && (
        <p class="mt-12 pt-8 border-t-3 border-brutal-black font-mono text-xs text-gray-500 uppercase tracking-wider">
          Last updated {new Date(updated).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
        </p>
      )}
    </div>
  </section>
</Layout>
